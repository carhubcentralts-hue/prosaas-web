# OpenAI API Key for voice generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Lead Webhook URL
# Set this to your webhook endpoint to receive lead submissions
# Example: https://your-system.com/webhook/leads
LEAD_WEBHOOK_URL=

# Public site URL (used for sitemap and robots.txt)
# Must match the canonical domain of the deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.prosaas.website
